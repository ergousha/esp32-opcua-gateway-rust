#!/usr/bin/env bash
# Pre-commit checks for esp32-opcua-gateway.
#
# This is a single bare-metal `no_std` crate (esp-hal, xtensa-esp32s3-none-elf),
# so unlike a workspace with a host-testable crate, even clippy needs the
# espup-installed `esp` toolchain — there's no faster host-target fallback.
# rustfmt doesn't invoke rustc so it's unaffected by the toolchain pin.
#
# Enable this hook once per clone with:
#   git config core.hooksPath .githooks
#
# Bypass it for a single commit (e.g. a WIP commit) with:
#   git commit --no-verify

set -euo pipefail

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

echo "pre-commit: cargo fmt --check"
RUSTUP_TOOLCHAIN=stable cargo fmt --all -- --check

echo "pre-commit: cargo clippy"
if [ -f "$HOME/export-esp.sh" ]; then
  # shellcheck disable=SC1091
  source "$HOME/export-esp.sh"
  cargo clippy --all-targets --all-features -- -D warnings
else
  echo "warning: ~/export-esp.sh not found, skipping clippy (run 'espup install --targets esp32s3' first)" >&2
fi

echo "pre-commit: all checks passed"
