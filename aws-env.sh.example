#!/usr/bin/env bash
# Loads AWS credentials into the shell. USAGE:
#   cp aws-env.sh.example aws-env.sh   # then fill in the real values
#   source ./aws-env.sh                # in every new terminal
#
# WARNING: aws-env.sh contains ACTUAL SECRET; it is in .gitignore, NEVER commit it.
# Access key is generated from the console: IAM -> Users -> <user> -> Security credentials
# -> Create access key (CLI). If compromised, immediately deactivate/delete it.

export AWS_ACCESS_KEY_ID="AKIA............"
export AWS_SECRET_ACCESS_KEY="................................"
export AWS_DEFAULT_REGION="eu-central-1"

# Verify:
#   source ./aws-env.sh && aws sts get-caller-identity
