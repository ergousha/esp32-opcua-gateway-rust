#!/usr/bin/env bash
# AWS kimlik bilgilerini kabuga yukler. KULLANIM:
#   cp aws-env.sh.example aws-env.sh   # sonra gercek degerleri doldur
#   source ./aws-env.sh                # her yeni terminalde
#
# UYARI: aws-env.sh GERCEK SIR icerir; .gitignore'da, ASLA commit'leme.
# Access key konsoldan uretilir: IAM -> Users -> <user> -> Security credentials
# -> Create access key (CLI). Sizarsa hemen deactivate/delete et.

export AWS_ACCESS_KEY_ID="AKIA............"
export AWS_SECRET_ACCESS_KEY="................................"
export AWS_DEFAULT_REGION="eu-central-1"

# Dogrula:
#   source ./aws-env.sh && aws sts get-caller-identity
